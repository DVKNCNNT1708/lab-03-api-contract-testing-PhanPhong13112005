{
	"info": {
		"name": "FIT4110_lab03_iot_ingestion",
		"description": "Collection kiểm thử tự động cho dịch vụ IoT Ingestion - Nhóm 8",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01_Functional",
			"item": [
				{
					"name": "Health Check (OK)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Service is UP\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"ok\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					}
				},
				{
					"name": "Nạp dữ liệu cảm biến (201 Created)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Response có chứa eventId và acceptedAt\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property(\"eventId\");",
									"    pm.expect(jsonData).to.have.property(\"acceptedAt\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{ "key": "token", "value": "{{authToken}}", "type": "string" }
							]
						},
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"deviceId\": \"SENSOR-001\",\n  \"timestamp\": \"2026-05-20T08:30:00Z\",\n  \"sensorData\": {\n    \"sensorType\": \"temp\",\n    \"value\": 25.5\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/telemetry",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "telemetry"]
						}
					}
				},
				{
					"name": "Lấy danh sách lịch sử đo đạc",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Trả về phân trang hợp lệ\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property(\"items\");",
									"    pm.expect(jsonData).to.have.property(\"hasMore\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{ "key": "token", "value": "{{authToken}}", "type": "string" }
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/telemetry",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "telemetry"]
						}
					}
				}
			]
